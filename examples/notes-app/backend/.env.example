# OpenRouter API key — required to actually stream from the LLM.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug — any OpenRouter chat-completion model with tool-calling.
# qwen/qwen3.6-plus verified end-to-end (tools + canonical AG-UI stream)
# with output_type=str (no structured-output envelope — see agent.py
# docstring for why).
OPENROUTER_MODEL=qwen/qwen3.6-plus

# Logfire — when set, observability spans (agent runs, repo ops, HTTP
# requests) flow to logfire automatically. ObservabilityProvider in
# main.py only activates if the ``logfire`` package is installed AND
# this token is exported in the env.
# Get one at https://logfire.pydantic.dev (write token).
LOGFIRE_TOKEN=
# Optional knobs forwarded to ObservabilityProvider(service_name=,
# environment=) — see ``pydantic_ai_stateflow.observability``.
LOGFIRE_SERVICE_NAME=notes-app
LOGFIRE_ENVIRONMENT=dev

# Framework-level python logging level for ``pydantic_ai_stateflow.*``
# loggers. Unset → NullHandler (silent). Set to DEBUG to see the
# streaming router / repo / shim debug stream in stderr.
STATEFLOW_LOG_LEVEL=

# Optional uvicorn binding (only consulted by `python -m notes_app`).
HOST=127.0.0.1
PORT=8000

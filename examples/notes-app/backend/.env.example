# OpenRouter API key — required to actually stream from the LLM.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug. OpenRouter routes a single model to many providers; pick one
# whose providers ALL support tool-calling — otherwise pydantic-ai will
# send `tool_choice` and OpenRouter may 404 on providers that don't accept
# it. Verified iteration-3 working defaults:
#   qwen/qwen-2.5-72b-instruct        ← recommended (tools rock-solid)
#   qwen/qwen3-235b-a22b-instruct     ← also fine
# Avoid `qwen/qwen3.6-plus` for now: some of its providers reject `tool_choice`.
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Optional uvicorn binding (only consulted by `python -m notes_app`).
HOST=127.0.0.1
PORT=8000

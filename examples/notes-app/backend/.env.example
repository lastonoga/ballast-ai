# OpenRouter API key — required to actually stream from the LLM.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug — any OpenRouter chat-completion model with tool-calling.
# qwen/qwen3.6-plus verified end-to-end (tools + canonical AG-UI stream)
# with output_type=str (no structured-output envelope — see agent.py
# docstring for why).
OPENROUTER_MODEL=qwen/qwen3.6-plus

# Sampling temperature forwarded into OpenRouterModelSettings (float).
# Defaults to 0.7 when unset.
OPENROUTER_TEMPERATURE=0.7

# Reasoning-token controls (all optional; leave unset for the model
# default). See https://openrouter.ai/docs/use-cases/reasoning-tokens
# OPENROUTER_REASONING_EFFORT      = low | medium | high
# OPENROUTER_REASONING_MAX_TOKENS  = positive int
# OPENROUTER_REASONING_ENABLED     = true | false
OPENROUTER_REASONING_EFFORT=
OPENROUTER_REASONING_MAX_TOKENS=
OPENROUTER_REASONING_ENABLED=

# Optional uvicorn binding (only consulted by `python -m notes_app`).
HOST=127.0.0.1
PORT=8000
